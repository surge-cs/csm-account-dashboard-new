# Backend Environment Variables for Railway
# The backend needs to authenticate with Google Sheets

# Google Sheets API Credentials (JSON key file contents)
# See: https://developers.google.com/sheets/api/guides/auth
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# Backend server port
PORT=3000

# CORS Origin (where your frontend is hosted)
# For Vercel: https://your-vercel-app.vercel.app
CORS_ORIGIN=http://localhost:5173

# Node environment
NODE_ENV=production
